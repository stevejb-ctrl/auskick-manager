# Deterministic Supabase CLI local-dev keys + test-only fallbacks.
# These are NOT secrets — every Supabase CLI install ships with
# this exact JWT pair, so they're safe to hard-code. The CI
# workflow (.github/workflows/ci.yml → "Load test env") copies
# this file to .env.test and exports each line into $GITHUB_ENV
# so `next build` / `next start` pick them up.
#
# If you bump the Supabase CLI to a major version that rotates the
# demo keys, regenerate this file via `supabase status -o env`.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Cron secret — any non-empty value is fine in tests. The cron
# route checks Authorization: Bearer <CRON_SECRET>; tests don't
# call /api/cron/sync-playhq, so the value just has to exist.
CRON_SECRET=test-cron-secret

# Super-admin credentials used by e2e/tests/auth.setup.ts. The setup
# spec calls ensureTestUser() which creates the account on first run
# via the admin API, so any deterministic value works — nothing
# pre-exists that we'd be authenticating against. The .test TLD is
# reserved (RFC 6761) so the email can never collide with a real
# Supabase account.
TEST_SUPER_ADMIN_EMAIL=super-admin@siren.test
TEST_SUPER_ADMIN_PASSWORD=test-pw-12345

# Resend / Telegram intentionally left unset so tests don't
# accidentally send real emails or Telegram messages. The relevant
# code paths (notifySignup, ContactForm) check for the env var and
# no-op when missing.
