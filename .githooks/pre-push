#!/usr/bin/env bash
# Pre-push gate: lint + vitest
#
# Why: two classes of "shouldn't ship to main" bugs have bitten before:
#
#   1. Lint errors that break `next build` (the Vercel deploy step
#      runs ESLint as part of compile). Unescaped JSX entities and
#      missing-key warnings have shipped twice this week — each one
#      cost a failed deploy + re-push round trip. Catching locally
#      costs ~10s.
#
#   2. Vitest regressions. ~735 unit tests cover the pure-function
#      sport logic (fairness, replayers, suggesters, validators). A
#      broken replayer or suggester is invisible to lint and to
#      `next build` but corrupts every downstream feature. Adding
#      vitest to the gate keeps main green at near-zero cost (~5s).
#
# Sequence: lint first (cheap, fails fast on the most common issue),
# then vitest (slower but more thorough).
#
# Bypass (use sparingly — only when you know the failure is pre-
# existing or you're pushing a WIP branch for review):
#
#   git push --no-verify
#
# Hook is wired via core.hooksPath = .githooks (set by the npm
# `prepare` script). To activate manually after cloning a fresh
# worktree without running `npm install`:
#
#   git config core.hooksPath .githooks
#
# To opt out for a single repo (e.g. you're debugging git itself):
#
#   git config --unset core.hooksPath

set -e

# Skip if there are no commits being pushed (e.g. `git push --tags`
# only, or a no-op push). The stdin protocol per `man githooks` —
# each line is "<local_ref> <local_oid> <remote_ref> <remote_oid>".
# If every local_oid is the zero OID, nothing's being pushed.
has_commits=0
while read -r _local_ref local_oid _remote_ref _remote_oid; do
  if [ "$local_oid" != "0000000000000000000000000000000000000000" ]; then
    has_commits=1
    break
  fi
done

if [ "$has_commits" = "0" ]; then
  exit 0
fi

echo "[pre-push] Running npm run lint…"

if ! npm run lint --silent; then
  echo ""
  echo "❌ [pre-push] Lint failed — push aborted."
  echo ""
  echo "Fix the errors above and try again. To bypass this check"
  echo "for a single push (e.g. WIP / draft PR), use:"
  echo ""
  echo "    git push --no-verify"
  echo ""
  exit 1
fi

echo "[pre-push] ✓ Lint clean."
echo "[pre-push] Running npm test (vitest)…"

if ! npm test --silent; then
  echo ""
  echo "❌ [pre-push] Vitest failed — push aborted."
  echo ""
  echo "Fix the failing tests above and try again. To bypass this"
  echo "check for a single push (e.g. you've inherited a pre-existing"
  echo "failure that isn't yours to fix right now), use:"
  echo ""
  echo "    git push --no-verify"
  echo ""
  exit 1
fi

echo "[pre-push] ✓ Vitest clean."
