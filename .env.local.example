NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# For local testing of the PlayHQ sync cron — set any value here, then pass it
# as Authorization: Bearer <value> when calling /api/cron/sync-playhq manually.
# In production Vercel generates and injects CRON_SECRET automatically.
CRON_SECRET=dev-secret
