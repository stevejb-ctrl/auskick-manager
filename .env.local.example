NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical public web host. Only consulted when the app is running
# inside the Capacitor native shell — on the web the helper falls
# back to window.location.origin so each brand keeps its own host.
# Native shells should set this to e.g. https://www.sirenfooty.com.au
# so password-reset emails and shared run/invite links point at the
# public site rather than capacitor://localhost.
NEXT_PUBLIC_PUBLIC_ORIGIN=

# For local testing of the PlayHQ sync cron — set any value here, then pass it
# as Authorization: Bearer <value> when calling /api/cron/sync-playhq manually.
# In production Vercel generates and injects CRON_SECRET automatically.
CRON_SECRET=dev-secret

# Resend — used by the /contact form (inbound to hello@sirenfooty.com.au)
# and by the team-invite email-send action (outbound to invitees).
# Sign up at resend.com, verify the sirenfooty.com.au domain (DNS records
# live at VentraIP), then paste the API key here. When this is unset,
# both call sites fail soft: contact form returns a friendly error,
# invite send writes a console warning + skips the network call so the
# in-app UX still works for local dev.
RESEND_API_KEY=
# Optional overrides. Defaults: from="Siren Footy <hello@sirenfooty.com.au>",
# to="hello@sirenfooty.com.au". Until the domain is verified in Resend, set
# RESEND_FROM_EMAIL="onboarding@resend.dev" so sending works from day one.
RESEND_FROM_EMAIL=
RESEND_TO_EMAIL=

# Telegram — used to notify the owner about signups, new teams, started
# games, and in-app feedback / presales questions submitted via the
# always-visible FeedbackFab.
# See docs/telegram-notifications.md for the three-step setup.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
