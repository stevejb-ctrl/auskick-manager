<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Custom URL scheme for OAuth deep-link callbacks. The
                 system browser bounces to siren://auth/callback?code=…
                 after Google / Apple sign-in completes; the OS routes
                 that intent here, NativeAuthBridge picks it up via
                 App.addListener('appUrlOpen'), and the WebView is
                 navigated to /auth/callback?code=… to exchange the
                 code for a session cookie on the same origin. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="siren" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- @capacitor/network needs ACCESS_NETWORK_STATE to expose
         connectivity status to the offline write queue (slice 5d).
         Without it Network.getStatus() returns unreliable data. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Required on Android 13+ (API 33+) for the OS to display
         push notifications. The first @capacitor/push-notifications
         registration call triggers the runtime permission prompt;
         without this declaration the prompt is suppressed and pushes
         arrive but never surface. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
</manifest>
